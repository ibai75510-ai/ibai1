# ── Backend ─────────────────────────────────────────────────────
JWT_SECRET=               # Secret used to sign local auth session tokens (use a long random string)

# ── Database (Supabase Postgres) ─────────────────────────────────
DATABASE_URL=             # Supabase connection string (postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true)

# ── Supabase Storage (file uploads) ───────────────────────────────
SUPABASE_URL=              # Project URL, e.g. https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY= # Settings -> API -> service_role key (server-side only, never expose to the browser)

# ── App ─────────────────────────────────────────────────────────
# Registration emails are sent via Supabase's own built-in Auth email sender
# (uses SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY above -- no extra provider needed).
APP_URL=http://localhost:3000
